//! base 0.1.0
package 'DemonstrateLightning'
  type 'Modelica.Electrical.Analog.Types.ImpulseApproximation' = enumeration('DoubleExp', 'Heidler');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  model 'DemonstrateLightning' "Demonstrate trajectory of lightning current"
    parameter Real 'T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    parameter 'Modelica.Electrical.Analog.Types.ImpulseApproximation' 'lightning1.approximation' = 'Modelica.Electrical.Analog.Types.ImpulseApproximation'.'DoubleExp' "Approximation of impulse";
    parameter Real 'lightning1.V'(unit = "V", quantity = "ElectricPotential") = 1e5 "Amplitude";
    parameter Real 'lightning1.T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'lightning1.T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    parameter Integer 'lightning1.m'(min = 2) = 5 "Integer exponent of Heidler-function 5..10";
    Real 'lightning1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'lightning1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'lightning1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'lightning1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'lightning1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'lightning1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter 'Modelica.Electrical.Analog.Types.ImpulseApproximation' 'lightning1.signalSource.approximation' = 'Modelica.Electrical.Analog.Types.ImpulseApproximation'.'DoubleExp' "Approximation of impulse";
    parameter Real 'lightning1.signalSource.amplitude' = 1e5 "Amplitude";
    parameter Real 'lightning1.signalSource.T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'lightning1.signalSource.T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    Real 'lightning1.signalSource.y' "Connector of Real output signal";
    parameter Real 'lightning1.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'lightning1.signalSource.startTime'(unit = "s", quantity = "Time") = 1e-5 "Output y = offset for time < startTime";
    parameter Integer 'lightning1.signalSource.m'(min = 2) = 5 "Integer exponent of Heidler-function 5..10";
    parameter Real 'lightning1.signalSource.eta'(fixed = false, start = 1.0, min = 2.2250738585072014e-308) "Amplitude parameter";
    parameter Real 'lightning1.signalSource.T0'(unit = "s", quantity = "Time") = 3.659917122121456e-5 "Initial value of time parameter";
    parameter Real 'lightning1.signalSource.T'(fixed = false, start = 3.659917122121456e-5, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time when maximum occurs";
    parameter Real 'lightning1.signalSource.T10'(fixed = false, start = 3.659917122121456e-7, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time to 10%";
    parameter Real 'lightning1.signalSource.tau1'(fixed = false, start = 3.5e-4, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time constant 1";
    parameter Real 'lightning1.signalSource.tau2'(fixed = false, start = 1e-5, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time constant 2";
    parameter Real 'lightning1.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'lightning1.startTime'(unit = "s", quantity = "Time") = 1e-5 "Time offset";
    parameter 'Modelica.Electrical.Analog.Types.ImpulseApproximation' 'lightning2.approximation' = 'Modelica.Electrical.Analog.Types.ImpulseApproximation'.'Heidler' "Approximation of impulse";
    parameter Real 'lightning2.I'(unit = "A", quantity = "ElectricCurrent") = 1e5 "Amplitude";
    parameter Real 'lightning2.T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'lightning2.T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    parameter Integer 'lightning2.m'(min = 2) = 5 "Integer exponent of Heidler-function 5..10";
    Real 'lightning2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'lightning2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'lightning2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'lightning2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'lightning2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'lightning2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter 'Modelica.Electrical.Analog.Types.ImpulseApproximation' 'lightning2.signalSource.approximation' = 'Modelica.Electrical.Analog.Types.ImpulseApproximation'.'Heidler' "Approximation of impulse";
    parameter Real 'lightning2.signalSource.amplitude' = 1e5 "Amplitude";
    parameter Real 'lightning2.signalSource.T1'(unit = "s", quantity = "Time") = 1e-5 "Rise time";
    parameter Real 'lightning2.signalSource.T2'(unit = "s", quantity = "Time") = 3.5e-4 "Decay time to half value";
    Real 'lightning2.signalSource.y' "Connector of Real output signal";
    parameter Real 'lightning2.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'lightning2.signalSource.startTime'(unit = "s", quantity = "Time") = 1e-5 "Output y = offset for time < startTime";
    parameter Integer 'lightning2.signalSource.m'(min = 2) = 5 "Integer exponent of Heidler-function 5..10";
    parameter Real 'lightning2.signalSource.eta'(fixed = false, start = 1.0, min = 2.2250738585072014e-308) "Amplitude parameter";
    parameter Real 'lightning2.signalSource.T0'(unit = "s", quantity = "Time") = 2.3650464499470163e-5 "Initial value of time parameter";
    parameter Real 'lightning2.signalSource.T'(fixed = false, start = 2.3650464499470163e-5, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time when maximum occurs";
    parameter Real 'lightning2.signalSource.T10'(fixed = false, start = 2.3650464499470163e-6, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time to 10%";
    parameter Real 'lightning2.signalSource.tau1'(fixed = false, start = 1e-5, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time constant 1";
    parameter Real 'lightning2.signalSource.tau2'(fixed = false, start = 3.5e-4, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") "Time constant 2";
    parameter Real 'lightning2.offset'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Current offset";
    parameter Real 'lightning2.startTime'(unit = "s", quantity = "Time") = 1e-5 "Time offset";
    Real 'ground1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'ground2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'resistor1.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1.0 "Resistance at temperature T_ref";
    parameter Real 'resistor1.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor1.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor1.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'resistor2.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1.0 "Resistance at temperature T_ref";
    parameter Real 'resistor2.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'resistor2.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'resistor2.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'resistor2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'resistor2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'resistor2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'resistor2.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'resistor2.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'resistor2.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'resistor2.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'resistor2.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'currentSensor1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor1.i'(unit = "A") "Current in the branch from p to n as output signal";
    Real 'currentSensor2.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor2.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor2.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'currentSensor2.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'currentSensor2.i'(unit = "A") "Current in the branch from p to n as output signal";
    parameter Real 'integrator1.k' = 1.0 "Integrator gain";
    parameter Boolean 'integrator1.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'integrator1.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'integrator1.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'integrator1.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'integrator1.u' "Connector of Real input signal";
    Real 'integrator1.y' "Connector of Real output signal";
    Boolean 'integrator1.local_reset';
    Real 'integrator1.local_set';
    Real 'der1.u' "Connector of Real input signal";
    Real 'der1.y' "Connector of Real output signal";
    parameter Real 'integrator2.k' = 1.0 "Integrator gain";
    parameter Boolean 'integrator2.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'integrator2.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'integrator2.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'integrator2.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'integrator2.u' "Connector of Real input signal";
    Real 'integrator2.y' "Connector of Real output signal";
    Boolean 'integrator2.local_reset';
    Real 'integrator2.local_set';
    Real 'der2.u' "Connector of Real input signal";
    Real 'der2.y' "Connector of Real output signal";
  initial equation
    exp(-'lightning1.signalSource.T' / 'lightning1.signalSource.tau1') / 'lightning1.signalSource.tau1' = exp(-'lightning1.signalSource.T' / 'lightning1.signalSource.tau2') / 'lightning1.signalSource.tau2';
    'lightning1.signalSource.eta' = exp(-'lightning1.signalSource.T' / 'lightning1.signalSource.tau1') - exp(-'lightning1.signalSource.T' / 'lightning1.signalSource.tau2');
    0.1 * 'lightning1.signalSource.eta' = exp(-'lightning1.signalSource.T10' / 'lightning1.signalSource.tau1') - exp(-'lightning1.signalSource.T10' / 'lightning1.signalSource.tau2');
    0.9 * 'lightning1.signalSource.eta' = exp(-('lightning1.signalSource.T10' + 8.000000000000001e-6) / 'lightning1.signalSource.tau1') - exp(-('lightning1.signalSource.T10' + 8.000000000000001e-6) / 'lightning1.signalSource.tau2');
    0.5 * 'lightning1.signalSource.eta' = exp(-('lightning1.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightning1.signalSource.tau1') - exp(-('lightning1.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightning1.signalSource.tau2');
    'lightning2.signalSource.tau2' / 'lightning2.signalSource.T' * 5.0 = 1.0 + ('lightning2.signalSource.T' / 'lightning2.signalSource.tau1') ^ 5.0;
    'lightning2.signalSource.eta' = ('lightning2.signalSource.T' / 'lightning2.signalSource.tau1') ^ 5.0 / (1.0 + ('lightning2.signalSource.T' / 'lightning2.signalSource.tau1') ^ 5.0) * exp(-'lightning2.signalSource.T' / 'lightning2.signalSource.tau2');
    0.1 * 'lightning2.signalSource.eta' = ('lightning2.signalSource.T10' / 'lightning2.signalSource.tau1') ^ 5.0 / (1.0 + ('lightning2.signalSource.T10' / 'lightning2.signalSource.tau1') ^ 5.0) * exp(-'lightning2.signalSource.T10' / 'lightning2.signalSource.tau2');
    0.9 * 'lightning2.signalSource.eta' = (('lightning2.signalSource.T10' + 8.000000000000001e-6) / 'lightning2.signalSource.tau1') ^ 5.0 / (1.0 + (('lightning2.signalSource.T10' + 8.000000000000001e-6) / 'lightning2.signalSource.tau1') ^ 5.0) * exp(-('lightning2.signalSource.T10' + 8.000000000000001e-6) / 'lightning2.signalSource.tau2');
    0.5 * 'lightning2.signalSource.eta' = (('lightning2.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightning2.signalSource.tau1') ^ 5.0 / (1.0 + (('lightning2.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightning2.signalSource.tau1') ^ 5.0) * exp(-('lightning2.signalSource.T10' - 1.0000000000000002e-6 + 3.5e-4) / 'lightning2.signalSource.tau2');
    'integrator1.y' = 0.0;
    'integrator2.y' = 0.0;
  equation
    'currentSensor1.i' = 'der1.u';
    'currentSensor1.i' = 'integrator1.u';
    'currentSensor2.i' = 'der2.u';
    'currentSensor2.i' = 'integrator2.u';
    'ground2.p.v' = 'resistor2.n.v';
    'ground2.p.v' = 'lightning2.p.v';
    'lightning1.n.v' = 'ground1.p.v';
    'lightning1.n.v' = 'resistor1.n.v';
    'currentSensor1.n.v' = 'resistor1.p.v';
    'lightning2.n.v' = 'currentSensor2.p.v';
    'currentSensor2.n.v' = 'resistor2.p.v';
    'lightning1.p.v' = 'currentSensor1.p.v';
    'currentSensor1.p.i' + 'lightning1.p.i' = 0.0;
    'resistor2.n.i' + 'ground2.p.i' + 'lightning2.p.i' = 0.0;
    'currentSensor2.p.i' + 'lightning2.n.i' = 0.0;
    'resistor1.n.i' + 'ground1.p.i' + 'lightning1.n.i' = 0.0;
    'currentSensor1.n.i' + 'resistor1.p.i' = 0.0;
    'currentSensor2.n.i' + 'resistor2.p.i' = 0.0;

    if time < 1e-5 then
      'lightning1.signalSource.y' = 0.0;
    else
      'lightning1.signalSource.y' = 1e5 / 'lightning1.signalSource.eta' * (exp(-(time - 1e-5) / 'lightning1.signalSource.tau1') - exp(-(time - 1e-5) / 'lightning1.signalSource.tau2'));
    end if;

    'lightning1.v' = 'lightning1.signalSource.y';
    0.0 = 'lightning1.p.i' + 'lightning1.n.i';
    'lightning1.i' = 'lightning1.p.i';
    'lightning1.v' = 'lightning1.p.v' - 'lightning1.n.v';

    if time < 1e-5 then
      'lightning2.signalSource.y' = 0.0;
    else
      'lightning2.signalSource.y' = 1e5 / 'lightning2.signalSource.eta' * ((time - 1e-5) / 'lightning2.signalSource.tau1') ^ 5.0 / (1.0 + ((time - 1e-5) / 'lightning2.signalSource.tau1') ^ 5.0) * exp(-(time - 1e-5) / 'lightning2.signalSource.tau2');
    end if;

    'lightning2.i' = 'lightning2.signalSource.y';
    0.0 = 'lightning2.p.i' + 'lightning2.n.i';
    'lightning2.i' = 'lightning2.p.i';
    'lightning2.v' = 'lightning2.p.v' - 'lightning2.n.v';
    'ground1.p.v' = 0.0;
    'ground2.p.v' = 0.0;
    'resistor1.R_actual' = 1.0;
    'resistor1.v' = 'resistor1.R_actual' * 'resistor1.i';
    'resistor1.LossPower' = 'resistor1.v' * 'resistor1.i';
    'resistor1.T_heatPort' = 300.15;
    0.0 = 'resistor1.p.i' + 'resistor1.n.i';
    'resistor1.i' = 'resistor1.p.i';
    'resistor1.v' = 'resistor1.p.v' - 'resistor1.n.v';
    'resistor2.R_actual' = 1.0;
    'resistor2.v' = 'resistor2.R_actual' * 'resistor2.i';
    'resistor2.LossPower' = 'resistor2.v' * 'resistor2.i';
    'resistor2.T_heatPort' = 300.15;
    0.0 = 'resistor2.p.i' + 'resistor2.n.i';
    'resistor2.i' = 'resistor2.p.i';
    'resistor2.v' = 'resistor2.p.v' - 'resistor2.n.v';
    'currentSensor1.p.v' = 'currentSensor1.n.v';
    'currentSensor1.p.i' = 'currentSensor1.i';
    'currentSensor1.n.i' = -'currentSensor1.i';
    'currentSensor2.p.v' = 'currentSensor2.n.v';
    'currentSensor2.p.i' = 'currentSensor2.i';
    'currentSensor2.n.i' = -'currentSensor2.i';
    'integrator1.local_reset' = false;
    'integrator1.local_set' = 0.0;
    der('integrator1.y') = 'integrator1.u';
    'der1.y' = der('der1.u');
    'integrator2.local_reset' = false;
    'integrator2.local_set' = 0.0;
    der('integrator2.y') = 'integrator2.u';
    'der2.y' = der('der2.u');
    annotation(experiment(StopTime = 0.001, Interval = 1e-07, Tolerance = 1e-06));
  end 'DemonstrateLightning';
end 'DemonstrateLightning';
