//! base 0.1.0
package 'PID_Controller'
  type 'Modelica.Blocks.Types.SimpleController' = enumeration('P', 'PI', 'PD', 'PID');

  type 'Modelica.Blocks.Types.Init' = enumeration('NoInit', 'SteadyState', 'InitialState', 'InitialOutput');

  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'PID_Controller' "Demonstrates the usage of a Continuous.LimPID controller"
    parameter Real 'driveAngle'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 1.570796326794897 "Reference distance to move";
    Real 'PI.u_s' "Connector of setpoint input signal";
    Real 'PI.u_m' "Connector of measurement input signal";
    Real 'PI.y' "Connector of actuator output signal";
    Real 'PI.controlError' "Control error (set point - measurement)";
    parameter 'Modelica.Blocks.Types.SimpleController' 'PI.controllerType' = 'Modelica.Blocks.Types.SimpleController'.'PI' "Type of controller";
    parameter Real 'PI.k' = 100.0 "Gain of controller, must be non-zero";
    parameter Real 'PI.Ti'(min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time constant of Integrator block";
    parameter Real 'PI.Td'(min = 0.0, unit = "s", quantity = "Time") = 0.1 "Time constant of Derivative block";
    parameter Real 'PI.yMax'(start = 1.0) = 12.0 "Upper limit of output";
    parameter Real 'PI.yMin' = -12.0 "Lower limit of output";
    parameter Real 'PI.wp'(min = 0.0) = 1.0 "Set-point weight for Proportional block (0..1)";
    parameter Real 'PI.wd'(min = 0.0) = 0.0 "Set-point weight for Derivative block (0..1)";
    parameter Real 'PI.Ni'(min = 2.220446049250313e-14) = 0.1 "Ni*Ti is time constant of anti-windup compensation";
    parameter Real 'PI.Nd'(min = 2.220446049250313e-14) = 10.0 "The higher Nd, the more ideal the derivative block";
    parameter Boolean 'PI.withFeedForward' = false "Use feed-forward input?" annotation(Evaluate = true);
    parameter Real 'PI.kFF' = 1.0 "Gain of feed-forward input";
    parameter 'Modelica.Blocks.Types.Init' 'PI.initType' = 'Modelica.Blocks.Types.Init'.'SteadyState' "Type of initialization (1: no init, 2: steady state, 3: initial state, 4: initial output)" annotation(Evaluate = true);
    parameter Real 'PI.xi_start' = 0.0 "Initial or guess value for integrator output (= integrator state)";
    parameter Real 'PI.xd_start' = 0.0 "Initial or guess value for state of derivative block";
    parameter Real 'PI.y_start' = 0.0 "Initial value of output";
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'PI.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'Linear' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    parameter Boolean 'PI.strict' = false "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    constant Real 'PI.unitTime'(unit = "s", quantity = "Time") = 1.0;
    Real 'PI.addP.u1' "Connector of Real input signal 1";
    Real 'PI.addP.u2' "Connector of Real input signal 2";
    Real 'PI.addP.y' "Connector of Real output signal";
    parameter Real 'PI.addP.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'PI.addP.k2' = -1.0 "Gain of input signal 2";
    parameter Real 'PI.P.k'(start = 1.0) = 1.0 "Gain value multiplied with input signal";
    Real 'PI.P.u' "Input signal connector";
    Real 'PI.P.y' "Output signal connector";
    parameter Real 'PI.I.k' = 10.0 "Integrator gain";
    parameter Boolean 'PI.I.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'PI.I.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'PI.I.initType' = 'Modelica.Blocks.Types.Init'.'SteadyState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'PI.I.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'PI.I.u' "Connector of Real input signal";
    Real 'PI.I.y' "Connector of Real output signal";
    Boolean 'PI.I.local_reset';
    Real 'PI.I.local_set';
    parameter Real 'PI.gainPID.k'(start = 1.0) = 100.0 "Gain value multiplied with input signal";
    Real 'PI.gainPID.u' "Input signal connector";
    Real 'PI.gainPID.y' "Output signal connector";
    parameter Real 'PI.addPID.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'PI.addPID.k2' = 1.0 "Gain of input signal 2";
    parameter Real 'PI.addPID.k3' = 1.0 "Gain of input signal 3";
    Real 'PI.addPID.u1' "Connector of Real input signal 1";
    Real 'PI.addPID.u2' "Connector of Real input signal 2";
    Real 'PI.addPID.u3' "Connector of Real input signal 3";
    Real 'PI.addPID.y' "Connector of Real output signal";
    parameter Real 'PI.addI.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'PI.addI.k2' = -1.0 "Gain of input signal 2";
    parameter Real 'PI.addI.k3' = 1.0 "Gain of input signal 3";
    Real 'PI.addI.u1' "Connector of Real input signal 1";
    Real 'PI.addI.u2' "Connector of Real input signal 2";
    Real 'PI.addI.u3' "Connector of Real input signal 3";
    Real 'PI.addI.y' "Connector of Real output signal";
    Real 'PI.addSat.u1' "Connector of Real input signal 1";
    Real 'PI.addSat.u2' "Connector of Real input signal 2";
    Real 'PI.addSat.y' "Connector of Real output signal";
    parameter Real 'PI.addSat.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'PI.addSat.k2' = -1.0 "Gain of input signal 2";
    parameter Real 'PI.gainTrack.k'(start = 1.0) = 0.1 "Gain value multiplied with input signal";
    Real 'PI.gainTrack.u' "Input signal connector";
    Real 'PI.gainTrack.y' "Output signal connector";
    parameter Real 'PI.limiter.uMax'(start = 1.0) = 12.0 "Upper limits of input signals";
    parameter Real 'PI.limiter.uMin' = -12.0 "Lower limits of input signals";
    parameter Boolean 'PI.limiter.strict' = false "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'PI.limiter.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'Linear' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'PI.limiter.u'(start = 0.0) "Connector of Real input signal";
    Real 'PI.limiter.y' "Connector of Real output signal";
    Real 'PI.limiter.simplifiedExpr' "Simplified expression for homotopy-based initialization";
    parameter Boolean 'PI.with_I' = true annotation(Evaluate = true);
    parameter Boolean 'PI.with_D' = false annotation(Evaluate = true);
    parameter Real 'PI.Dzero.k'(start = 1.0) = 0.0 "Constant output value";
    Real 'PI.Dzero.y' "Connector of Real output signal";
    parameter Real 'PI.FFzero.k'(start = 1.0) = 0.0 "Constant output value";
    Real 'PI.FFzero.y' "Connector of Real output signal";
    Real 'PI.addFF.u1' "Connector of Real input signal 1";
    Real 'PI.addFF.u2' "Connector of Real input signal 2";
    Real 'PI.addFF.y' "Connector of Real output signal";
    parameter Real 'PI.addFF.k1' = 1.0 "Gain of input signal 1";
    parameter Real 'PI.addFF.k2' = 1.0 "Gain of input signal 2";
    Real 'inertia1.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia1.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inertia1.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia1.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'inertia1.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 1.0 "Moment of inertia";
    parameter StateSelect 'inertia1.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'inertia1.phi'(stateSelect = StateSelect.default, fixed = true, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'inertia1.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'inertia1.a'(fixed = true, start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Boolean 'torque.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'torque.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'torque.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'torque.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'torque.tau'(unit = "N.m") "Accelerating torque acting at flange (= -flange.tau)";
    parameter Real 'spring.c'(start = 1e5, min = 0.0, unit = "N.m/rad", quantity = "RotationalSpringConstant") = 1e4 "Spring constant";
    parameter Real 'spring.d'(start = 0.0, min = 0.0, unit = "N.m.s/rad", quantity = "RotationalDampingConstant") = 100.0 "Damping constant";
    parameter Real 'spring.phi_rel0'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Unstretched spring angle";
    Real 'spring.phi_rel'(stateSelect = StateSelect.prefer, nominal = 1e-4, start = 0.0, displayUnit = "deg", unit = "rad", quantity = "Angle") "Relative rotation angle (= flange_b.phi - flange_a.phi)";
    Real 'spring.w_rel'(stateSelect = StateSelect.prefer, fixed = true, start = 0.0, unit = "rad/s", quantity = "AngularVelocity") "Relative angular velocity (= der(phi_rel))";
    Real 'spring.a_rel'(start = 0.0, unit = "rad/s2", quantity = "AngularAcceleration") "Relative angular acceleration (= der(w_rel))";
    Real 'spring.tau'(unit = "N.m", quantity = "Torque") "Torque between flanges (= flange_b.tau)";
    Real 'spring.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'spring.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'spring.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'spring.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'spring.phi_nominal'(min = 0.0, displayUnit = "rad", unit = "rad", quantity = "Angle") = 1e-4 "Nominal value of phi_rel (used for scaling)";
    parameter StateSelect 'spring.stateSelect' = StateSelect.prefer "Priority to use phi_rel and w_rel as states";
    parameter Boolean 'spring.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    Real 'spring.lossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort (> 0, if heat is flowing out of component)";
    Real 'spring.tau_c'(unit = "N.m", quantity = "Torque") "Spring torque";
    Real 'spring.tau_d'(unit = "N.m", quantity = "Torque") "Damping torque";
    Real 'inertia2.flange_a.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia2.flange_a.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'inertia2.flange_b.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'inertia2.flange_b.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    parameter Real 'inertia2.J'(start = 1.0, min = 0.0, unit = "kg.m2", quantity = "MomentOfInertia") = 2.0 "Moment of inertia";
    parameter StateSelect 'inertia2.stateSelect' = StateSelect.default "Priority to use phi and w as states";
    Real 'inertia2.phi'(stateSelect = StateSelect.default, displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of component";
    Real 'inertia2.w'(stateSelect = StateSelect.default, unit = "rad/s", quantity = "AngularVelocity") "Absolute angular velocity of component (= der(phi))";
    Real 'inertia2.a'(unit = "rad/s2", quantity = "AngularAcceleration") "Absolute angular acceleration of component (= der(w))";
    parameter Real 'kinematicPTP.deltaq[1]' = 1.570796326794897 "Distance to move";
    parameter Real 'kinematicPTP.qd_max[1]'(min = 2.2250738585072014e-308) = 1.0 "Maximum velocities der(q)";
    parameter Real 'kinematicPTP.qdd_max[1]'(min = 2.2250738585072014e-308) = 1.0 "Maximum accelerations der(qd)";
    parameter Real 'kinematicPTP.startTime'(unit = "s", quantity = "Time") = 0.5 "Time instant at which movement starts";
    parameter Integer 'kinematicPTP.nout'(min = 1) = 1 "Number of outputs";
    Real 'kinematicPTP.y[1]' "Connector of Real output signals";
    parameter Real 'kinematicPTP.p_deltaq[1]' = 1.570796326794897;
    parameter Real 'kinematicPTP.p_qd_max[1]' = 1.0;
    parameter Real 'kinematicPTP.p_qdd_max[1]' = 1.0;
    Real 'kinematicPTP.sd_max';
    Real 'kinematicPTP.sdd_max';
    Real 'kinematicPTP.sdd';
    Real 'kinematicPTP.aux1[1]';
    Real 'kinematicPTP.aux2[1]';
    Real 'kinematicPTP.Ta1'(unit = "s", quantity = "Time");
    Real 'kinematicPTP.Ta2'(unit = "s", quantity = "Time");
    Real 'kinematicPTP.Tv'(unit = "s", quantity = "Time");
    Real 'kinematicPTP.Te'(unit = "s", quantity = "Time");
    Boolean 'kinematicPTP.noWphase';
    parameter Real 'integrator.k' = 1.0 "Integrator gain";
    parameter Boolean 'integrator.use_reset' = false "= true, if reset port enabled" annotation(Evaluate = true);
    parameter Boolean 'integrator.use_set' = false "= true, if set port enabled and used as reinitialization value when reset" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.Init' 'integrator.initType' = 'Modelica.Blocks.Types.Init'.'InitialState' "Type of initialization (1: no init, 2: steady state, 3,4: initial output)" annotation(Evaluate = true);
    parameter Real 'integrator.y_start' = 0.0 "Initial or guess value of output (= state)";
    Real 'integrator.u' "Connector of Real input signal";
    Real 'integrator.y' "Connector of Real output signal";
    Boolean 'integrator.local_reset';
    Real 'integrator.local_set';
    Real 'speedSensor.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'speedSensor.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'speedSensor.w'(unit = "rad/s") "Absolute angular velocity of flange as output signal";
    parameter Boolean 'loadTorque.useSupport' = false "= true, if support flange enabled, otherwise implicitly grounded" annotation(Evaluate = true);
    Real 'loadTorque.flange.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute rotation angle of flange";
    Real 'loadTorque.flange.tau'(unit = "N.m", quantity = "Torque") "Cut torque in the flange";
    Real 'loadTorque.phi_support'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Absolute angle of support flange";
    Real 'loadTorque.phi'(displayUnit = "deg", unit = "rad", quantity = "Angle") "Angle of flange with respect to support (= flange.phi - support.phi)";
    parameter Real 'loadTorque.tau_constant'(unit = "N.m", quantity = "Torque") = 10.0 "Constant torque (if negative, torque is acting as load in positive direction of rotation)";
    Real 'loadTorque.w'(unit = "rad/s", quantity = "AngularVelocity") "Angular velocity of flange with respect to support (= der(phi))";
    Real 'loadTorque.tau'(unit = "N.m", quantity = "Torque") "Accelerating torque acting at flange (= -flange.tau)";
  initial equation
    der('PI.I.y') = 0.0;
    'integrator.y' = 0.0;
    der('spring.w_rel') = 0.0;
  equation
    'PI.controlError' = 'PI.u_s' - 'PI.u_m';
    'PI.u_s' = 'PI.addI.u1';
    'PI.u_s' = 'PI.addP.u1';
    'PI.addP.y' = 'PI.P.u';
    'PI.addI.y' = 'PI.I.u';
    'PI.P.y' = 'PI.addPID.u1';
    'PI.I.y' = 'PI.addPID.u3';
    'PI.limiter.y' = 'PI.y';
    'PI.limiter.y' = 'PI.addSat.u1';
    'PI.addSat.y' = 'PI.gainTrack.u';
    'PI.gainTrack.y' = 'PI.addI.u3';
    'PI.u_m' = 'PI.addI.u2';
    'PI.u_m' = 'PI.addP.u2';
    'PI.Dzero.y' = 'PI.addPID.u2';
    'PI.addPID.y' = 'PI.gainPID.u';
    'PI.addFF.y' = 'PI.addSat.u2';
    'PI.addFF.y' = 'PI.limiter.u';
    'PI.gainPID.y' = 'PI.addFF.u1';
    'PI.FFzero.y' = 'PI.addFF.u2';
    'spring.flange_b.phi' = 'inertia2.flange_a.phi';
    'speedSensor.flange.phi' = 'inertia1.flange_b.phi';
    'speedSensor.flange.phi' = 'spring.flange_a.phi';
    'torque.flange.phi' = 'inertia1.flange_a.phi';
    'kinematicPTP.y[1]' = 'integrator.u';
    'loadTorque.flange.phi' = 'inertia2.flange_b.phi';
    'PI.y' = 'torque.tau';
    'speedSensor.w' = 'PI.u_m';
    'integrator.y' = 'PI.u_s';
    'torque.flange.tau' + 'inertia1.flange_a.tau' = 0.0;
    'speedSensor.flange.tau' + 'spring.flange_a.tau' + 'inertia1.flange_b.tau' = 0.0;
    'inertia2.flange_a.tau' + 'spring.flange_b.tau' = 0.0;
    'loadTorque.flange.tau' + 'inertia2.flange_b.tau' = 0.0;
    'PI.addP.y' = 'PI.addP.u1' + (-1.0) * 'PI.addP.u2';
    'PI.P.y' = 'PI.P.u';
    'PI.I.local_reset' = false;
    'PI.I.local_set' = 0.0;
    der('PI.I.y') = 10.0 * 'PI.I.u';
    'PI.gainPID.y' = 100.0 * 'PI.gainPID.u';
    'PI.addPID.y' = 'PI.addPID.u1' + 'PI.addPID.u2' + 'PI.addPID.u3';
    'PI.addI.y' = 'PI.addI.u1' + (-1.0) * 'PI.addI.u2' + 'PI.addI.u3';
    'PI.addSat.y' = 'PI.addSat.u1' + (-1.0) * 'PI.addSat.u2';
    'PI.gainTrack.y' = 0.1 * 'PI.gainTrack.u';
    'PI.limiter.simplifiedExpr' = 'PI.limiter.u';
    'PI.limiter.y' = homotopy(smooth(0, if 'PI.limiter.u' > 12.0 then 12.0 else if 'PI.limiter.u' < (-12.0) then -12.0 else 'PI.limiter.u'), 'PI.limiter.simplifiedExpr');
    'PI.Dzero.y' = 0.0;
    'PI.FFzero.y' = 0.0;
    'PI.addFF.y' = 'PI.addFF.u1' + 'PI.addFF.u2';
    'inertia1.phi' = 'inertia1.flange_a.phi';
    'inertia1.phi' = 'inertia1.flange_b.phi';
    'inertia1.w' = der('inertia1.phi');
    'inertia1.a' = der('inertia1.w');
    'inertia1.a' = 'inertia1.flange_a.tau' + 'inertia1.flange_b.tau';
    'torque.flange.tau' = -'torque.tau';
    'torque.phi_support' = 0.0;
    'spring.tau_c' = 1e4 * 'spring.phi_rel';
    'spring.tau_d' = 100.0 * 'spring.w_rel';
    'spring.tau' = 'spring.tau_c' + 'spring.tau_d';
    'spring.lossPower' = 'spring.tau_d' * 'spring.w_rel';
    'spring.phi_rel' = 'spring.flange_b.phi' - 'spring.flange_a.phi';
    'spring.w_rel' = der('spring.phi_rel');
    'spring.a_rel' = der('spring.w_rel');
    'spring.flange_b.tau' = 'spring.tau';
    'spring.flange_a.tau' = -'spring.tau';
    'inertia2.phi' = 'inertia2.flange_a.phi';
    'inertia2.phi' = 'inertia2.flange_b.phi';
    'inertia2.w' = der('inertia2.phi');
    'inertia2.a' = der('inertia2.w');
    2.0 * 'inertia2.a' = 'inertia2.flange_a.tau' + 'inertia2.flange_b.tau';
    'kinematicPTP.aux1[1]' = 1.570796326794897;
    'kinematicPTP.aux2[1]' = 1.570796326794897;
    'kinematicPTP.sd_max' = 1.0 / abs('kinematicPTP.aux1[1]');
    'kinematicPTP.sdd_max' = 1.0 / abs('kinematicPTP.aux2[1]');
    'kinematicPTP.Ta1' = sqrt(1.0 / 'kinematicPTP.sdd_max');
    'kinematicPTP.Ta2' = 'kinematicPTP.sd_max' / 'kinematicPTP.sdd_max';
    'kinematicPTP.noWphase' = 'kinematicPTP.Ta2' >= 'kinematicPTP.Ta1';
    'kinematicPTP.Tv' = if 'kinematicPTP.noWphase' then 'kinematicPTP.Ta1' else 1.0 / 'kinematicPTP.sd_max';
    'kinematicPTP.Te' = if 'kinematicPTP.noWphase' then 'kinematicPTP.Ta1' + 'kinematicPTP.Ta1' else 'kinematicPTP.Tv' + 'kinematicPTP.Ta2';
    'kinematicPTP.sdd' = if time < 0.5 then 0.0 else if 'kinematicPTP.noWphase' then if time < 'kinematicPTP.Ta1' + 0.5 then 'kinematicPTP.sdd_max' else if time < 'kinematicPTP.Te' + 0.5 then -'kinematicPTP.sdd_max' else 0.0 else if time < 'kinematicPTP.Ta2' + 0.5 then 'kinematicPTP.sdd_max' else if time < 'kinematicPTP.Tv' + 0.5 then 0.0 else if time < 'kinematicPTP.Te' + 0.5 then -'kinematicPTP.sdd_max' else 0.0;
    'kinematicPTP.y[1]' = 1.570796326794897 * 'kinematicPTP.sdd';
    'integrator.local_reset' = false;
    'integrator.local_set' = 0.0;
    der('integrator.y') = 'integrator.u';
    'speedSensor.w' = der('speedSensor.flange.phi');
    0.0 = 'speedSensor.flange.tau';
    'loadTorque.w' = der('loadTorque.phi');
    'loadTorque.tau' = -'loadTorque.flange.tau';
    'loadTorque.tau' = 10.0;
    'loadTorque.phi' = 'loadTorque.flange.phi' - 'loadTorque.phi_support';
    'loadTorque.phi_support' = 0.0;
    annotation(experiment(StopTime = 4));
  end 'PID_Controller';
end 'PID_Controller';
