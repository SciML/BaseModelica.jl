    Real 'With_Ron_Goff_Vknee.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'With_Ron_Goff_Vknee.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'With_Ron_Goff_Vknee.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
