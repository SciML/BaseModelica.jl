//! base 0.1.0
package 'SimpleTriacCircuit'
  model 'SimpleTriacCircuit' "Simple triac test circuit"
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'L.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'L.p.v'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'L.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'L.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'L.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'L.i'(fixed = true, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'L.L'(start = 1.0, unit = "H", quantity = "Inductance") = 2e-6 "Inductance";
    parameter Real 'R.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 10.0 "Resistance at temperature T_ref";
    parameter Real 'R.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'R.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'R.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'R.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'R.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'R.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'R.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'R.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'R.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'R.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'R.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'R.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'R.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
    parameter Real 'V.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 30.0 "Amplitude of sine wave";
    parameter Real 'V.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Real 'V.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1e4 "Frequency of sine wave";
    Real 'V.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'V.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'V.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'V.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'V.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'V.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'V.signalSource.amplitude' = 30.0 "Amplitude of sine wave";
    parameter Real 'V.signalSource.f'(start = 1.0, unit = "Hz", quantity = "Frequency") = 1e4 "Frequency of sine wave";
    parameter Real 'V.signalSource.phase'(displayUnit = "deg", unit = "rad", quantity = "Angle") = 0.0 "Phase of sine wave";
    parameter Boolean 'V.signalSource.continuous' = false "Make output continuous by starting at offset + amplitude*sin(phase)" annotation(Evaluate = true);
    Real 'V.signalSource.y' "Connector of Real output signal";
    parameter Real 'V.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'V.signalSource.startTime'(unit = "s", quantity = "Time") = 0.0 "Output y = offset for time < startTime";
    parameter Real 'V.offset'(unit = "V", quantity = "ElectricPotential") = 0.0 "Voltage offset";
    parameter Real 'V.startTime'(unit = "s", quantity = "Time") = 0.0 "Time offset";
    parameter Real 'simpleTriac.VDRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 400.0 "Forward breakthrough voltage";
    parameter Real 'simpleTriac.VRRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 400.0 "Reverse breakthrough voltage";
    parameter Real 'simpleTriac.IDRM'(unit = "A", quantity = "ElectricCurrent") = 0.1 "Saturation current";
    parameter Real 'simpleTriac.VTM'(unit = "V", quantity = "ElectricPotential") = 1.7 "Conducting voltage";
    parameter Real 'simpleTriac.IH'(unit = "A", quantity = "ElectricCurrent") = 0.006 "Holding current";
    parameter Real 'simpleTriac.ITM'(unit = "A", quantity = "ElectricCurrent") = 25.0 "Conducting current";
    parameter Real 'simpleTriac.VGT'(unit = "V", quantity = "ElectricPotential") = 0.7 "Gate trigger voltage";
    parameter Real 'simpleTriac.IGT'(unit = "A", quantity = "ElectricCurrent") = 0.005 "Gate trigger current";
    parameter Real 'simpleTriac.TON'(unit = "s", quantity = "Time") = 1e-6 "Switch on time";
    parameter Real 'simpleTriac.TOFF'(unit = "s", quantity = "Time") = 1.5e-5 "Switch off time";
    parameter Real 'simpleTriac.Vt'(unit = "V", quantity = "ElectricPotential") = 0.04 "Voltage equivalent of temperature (kT/qn)";
    parameter Real 'simpleTriac.Nbv' = 0.74 "Reverse Breakthrough emission coefficient";
    Real 'simpleTriac.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.g.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.g.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'simpleTriac.thyristor.VDRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 400.0 "Forward breakthrough voltage";
    parameter Real 'simpleTriac.thyristor.VRRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 400.0 "Reverse breakthrough voltage";
    parameter Real 'simpleTriac.thyristor.IDRM'(unit = "A", quantity = "ElectricCurrent") = 0.1 "Saturation current";
    parameter Real 'simpleTriac.thyristor.VTM'(unit = "V", quantity = "ElectricPotential") = 1.7 "Conducting voltage";
    parameter Real 'simpleTriac.thyristor.IH'(unit = "A", quantity = "ElectricCurrent") = 0.006 "Holding current";
    parameter Real 'simpleTriac.thyristor.ITM'(unit = "A", quantity = "ElectricCurrent") = 25.0 "Conducting current";
    parameter Real 'simpleTriac.thyristor.VGT'(unit = "V", quantity = "ElectricPotential") = 0.7 "Gate trigger voltage";
    parameter Real 'simpleTriac.thyristor.IGT'(unit = "A", quantity = "ElectricCurrent") = 0.005 "Gate trigger current";
    parameter Real 'simpleTriac.thyristor.TON'(unit = "s", quantity = "Time") = 1e-6 "Switch on time";
    parameter Real 'simpleTriac.thyristor.TOFF'(unit = "s", quantity = "Time") = 1.5e-5 "Switch off time";
    parameter Real 'simpleTriac.thyristor.Vt'(unit = "V", quantity = "ElectricPotential") = 0.04 "Voltage equivalent of temperature (kT/qn)";
    parameter Real 'simpleTriac.thyristor.Nbv' = 0.74 "Reverse Breakthrough emission coefficient";
    parameter Boolean 'simpleTriac.thyristor.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'simpleTriac.thyristor.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'simpleTriac.thyristor.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'simpleTriac.thyristor.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'simpleTriac.thyristor.iGK'(unit = "A", quantity = "ElectricCurrent") "Gate current";
    Real 'simpleTriac.thyristor.vGK'(unit = "V", quantity = "ElectricPotential") "Voltage between gate and cathode";
    Real 'simpleTriac.thyristor.vAK'(unit = "V", quantity = "ElectricPotential") "Voltage between anode and cathode";
    Real 'simpleTriac.thyristor.vControl'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'simpleTriac.thyristor.vContot'(unit = "V", quantity = "ElectricPotential");
    Real 'simpleTriac.thyristor.vConmain'(unit = "V", quantity = "ElectricPotential");
    parameter Real 'simpleTriac.thyristor.vRef'(unit = "V", quantity = "ElectricPotential") = 0.65;
    Real 'simpleTriac.thyristor.Anode.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.thyristor.Anode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.thyristor.Cathode.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.thyristor.Cathode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.thyristor.Gate.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.thyristor.Gate.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'simpleTriac.thyristor.Von'(unit = "V", quantity = "ElectricPotential") = 5.0;
    parameter Real 'simpleTriac.thyristor.Voff'(unit = "V", quantity = "ElectricPotential") = 1.5;
    parameter Real 'simpleTriac.thyristor.Ron'(unit = "Ohm", quantity = "Resistance") = 0.04 "Forward conducting mode resistance";
    parameter Real 'simpleTriac.thyristor.Roff'(unit = "Ohm", quantity = "Resistance") = 1.5686274509803923e7 "Blocking mode resistance";
    parameter Real 'simpleTriac.thyristor1.VDRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 400.0 "Forward breakthrough voltage";
    parameter Real 'simpleTriac.thyristor1.VRRM'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 400.0 "Reverse breakthrough voltage";
    parameter Real 'simpleTriac.thyristor1.IDRM'(unit = "A", quantity = "ElectricCurrent") = 0.1 "Saturation current";
    parameter Real 'simpleTriac.thyristor1.VTM'(unit = "V", quantity = "ElectricPotential") = 1.7 "Conducting voltage";
    parameter Real 'simpleTriac.thyristor1.IH'(unit = "A", quantity = "ElectricCurrent") = 0.006 "Holding current";
    parameter Real 'simpleTriac.thyristor1.ITM'(unit = "A", quantity = "ElectricCurrent") = 25.0 "Conducting current";
    parameter Real 'simpleTriac.thyristor1.VGT'(unit = "V", quantity = "ElectricPotential") = 0.7 "Gate trigger voltage";
    parameter Real 'simpleTriac.thyristor1.IGT'(unit = "A", quantity = "ElectricCurrent") = 0.005 "Gate trigger current";
    parameter Real 'simpleTriac.thyristor1.TON'(unit = "s", quantity = "Time") = 1e-6 "Switch on time";
    parameter Real 'simpleTriac.thyristor1.TOFF'(unit = "s", quantity = "Time") = 1.5e-5 "Switch off time";
    parameter Real 'simpleTriac.thyristor1.Vt'(unit = "V", quantity = "ElectricPotential") = 0.04 "Voltage equivalent of temperature (kT/qn)";
    parameter Real 'simpleTriac.thyristor1.Nbv' = 0.74 "Reverse Breakthrough emission coefficient";
    parameter Boolean 'simpleTriac.thyristor1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'simpleTriac.thyristor1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'simpleTriac.thyristor1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'simpleTriac.thyristor1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'simpleTriac.thyristor1.iGK'(unit = "A", quantity = "ElectricCurrent") "Gate current";
    Real 'simpleTriac.thyristor1.vGK'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage between gate and cathode";
    Real 'simpleTriac.thyristor1.vAK'(unit = "V", quantity = "ElectricPotential") "Voltage between anode and cathode";
    Real 'simpleTriac.thyristor1.vControl'(start = 0.0, unit = "V", quantity = "ElectricPotential");
    Real 'simpleTriac.thyristor1.vContot'(unit = "V", quantity = "ElectricPotential");
    Real 'simpleTriac.thyristor1.vConmain'(unit = "V", quantity = "ElectricPotential");
    parameter Real 'simpleTriac.thyristor1.vRef'(unit = "V", quantity = "ElectricPotential") = 0.65;
    Real 'simpleTriac.thyristor1.Anode.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.thyristor1.Anode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.thyristor1.Cathode.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.thyristor1.Cathode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.thyristor1.Gate.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.thyristor1.Gate.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'simpleTriac.thyristor1.Von'(unit = "V", quantity = "ElectricPotential") = 5.0;
    parameter Real 'simpleTriac.thyristor1.Voff'(unit = "V", quantity = "ElectricPotential") = 1.5;
    parameter Real 'simpleTriac.thyristor1.Ron'(unit = "Ohm", quantity = "Resistance") = 0.04 "Forward conducting mode resistance";
    parameter Real 'simpleTriac.thyristor1.Roff'(unit = "Ohm", quantity = "Resistance") = 1.5686274509803923e7 "Blocking mode resistance";
    Real 'simpleTriac.idealDiode.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'simpleTriac.idealDiode.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.idealDiode.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.idealDiode.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.idealDiode.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.idealDiode.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'simpleTriac.idealDiode.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'simpleTriac.idealDiode.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'simpleTriac.idealDiode.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'simpleTriac.idealDiode.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'simpleTriac.idealDiode.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'simpleTriac.idealDiode.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'simpleTriac.idealDiode.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'simpleTriac.idealDiode.off'(start = true) "Switching state";
    Real 'simpleTriac.idealDiode.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'simpleTriac.idealDiode.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'simpleTriac.idealDiode.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    Real 'simpleTriac.idealDiode1.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'simpleTriac.idealDiode1.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.idealDiode1.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.idealDiode1.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'simpleTriac.idealDiode1.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'simpleTriac.idealDiode1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'simpleTriac.idealDiode1.Ron'(min = 0.0, unit = "Ohm", quantity = "Resistance") = 1e-5 "Forward state-on differential resistance (closed resistance)";
    parameter Real 'simpleTriac.idealDiode1.Goff'(min = 0.0, unit = "S", quantity = "Conductance") = 1e-5 "Backward state-off conductance (opened conductance)";
    parameter Real 'simpleTriac.idealDiode1.Vknee'(min = 0.0, unit = "V", quantity = "ElectricPotential") = 0.0 "Forward threshold voltage";
    parameter Boolean 'simpleTriac.idealDiode1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'simpleTriac.idealDiode1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'simpleTriac.idealDiode1.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'simpleTriac.idealDiode1.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Boolean 'simpleTriac.idealDiode1.off'(start = true) "Switching state";
    Real 'simpleTriac.idealDiode1.s'(start = 0.0, unit = "1") "Auxiliary variable for actual position on the ideal diode characteristic";
    constant Real 'simpleTriac.idealDiode1.unitVoltage'(unit = "V", quantity = "ElectricPotential") = 1.0;
    constant Real 'simpleTriac.idealDiode1.unitCurrent'(unit = "A", quantity = "ElectricCurrent") = 1.0;
    parameter Boolean 'simpleTriac.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'simpleTriac.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
    Real 'simpleTriac.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'simpleTriac.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    parameter Real 'trapezoidCurrent.I'(start = 1.0, unit = "A", quantity = "ElectricCurrent") = 0.005 "Amplitude of trapezoid";
    parameter Real 'trapezoidCurrent.rising'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 1e-6 "Rising duration of trapezoid";
    parameter Real 'trapezoidCurrent.width'(start = 0.5, min = 0.0, unit = "s", quantity = "Time") = 5e-6 "Width duration of trapezoid";
    parameter Real 'trapezoidCurrent.falling'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 1e-6 "Falling duration of trapezoid";
    parameter Real 'trapezoidCurrent.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 5e-5 "Time for one period";
    parameter Integer 'trapezoidCurrent.nperiod'(start = -1) = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'trapezoidCurrent.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'trapezoidCurrent.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'trapezoidCurrent.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'trapezoidCurrent.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'trapezoidCurrent.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'trapezoidCurrent.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'trapezoidCurrent.signalSource.amplitude' = 0.005 "Amplitude of trapezoid";
    parameter Real 'trapezoidCurrent.signalSource.rising'(min = 0.0, unit = "s", quantity = "Time") = 1e-6 "Rising duration of trapezoid";
    parameter Real 'trapezoidCurrent.signalSource.width'(min = 0.0, unit = "s", quantity = "Time") = 5e-6 "Width duration of trapezoid";
    parameter Real 'trapezoidCurrent.signalSource.falling'(min = 0.0, unit = "s", quantity = "Time") = 1e-6 "Falling duration of trapezoid";
    parameter Real 'trapezoidCurrent.signalSource.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 5e-5 "Time for one period";
    parameter Integer 'trapezoidCurrent.signalSource.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'trapezoidCurrent.signalSource.y' "Connector of Real output signal";
    parameter Real 'trapezoidCurrent.signalSource.offset' = 0.0 "Offset of output signal y";
    parameter Real 'trapezoidCurrent.signalSource.startTime'(unit = "s", quantity = "Time") = 2e-5 "Output y = offset for time < startTime";
    parameter Real 'trapezoidCurrent.signalSource.T_rising'(unit = "s", quantity = "Time") = 1e-6 "End time of rising phase within one period";
    parameter Real 'trapezoidCurrent.signalSource.T_width'(unit = "s", quantity = "Time") = 6e-6 "End time of width phase within one period";
    parameter Real 'trapezoidCurrent.signalSource.T_falling'(unit = "s", quantity = "Time") = 7e-6 "End time of falling phase within one period";
    Real 'trapezoidCurrent.signalSource.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'trapezoidCurrent.signalSource.count' "Period count";
    parameter Real 'trapezoidCurrent.offset'(unit = "A", quantity = "ElectricCurrent") = 0.0 "Current offset";
    parameter Real 'trapezoidCurrent.startTime'(unit = "s", quantity = "Time") = 2e-5 "Time offset";
  initial equation
    'simpleTriac.thyristor.vControl' = 0.0;
    'simpleTriac.thyristor1.vControl' = 0.0;
  equation
    'simpleTriac.thyristor1.Cathode.v' = 'simpleTriac.thyristor.Anode.v';
    'simpleTriac.thyristor1.Cathode.v' = 'simpleTriac.n.v';
    'simpleTriac.thyristor1.Cathode.i' + 'simpleTriac.thyristor.Anode.i' - 'simpleTriac.n.i' = 0.0;
    'simpleTriac.thyristor1.Anode.v' = 'simpleTriac.thyristor.Cathode.v';
    'simpleTriac.thyristor1.Anode.v' = 'simpleTriac.p.v';
    'simpleTriac.thyristor1.Anode.i' + 'simpleTriac.thyristor.Cathode.i' - 'simpleTriac.p.i' = 0.0;
    'simpleTriac.thyristor.Gate.v' = 'simpleTriac.idealDiode.n.v';
    'simpleTriac.idealDiode1.p.v' = 'simpleTriac.g.v';
    'simpleTriac.idealDiode1.p.v' = 'simpleTriac.idealDiode.p.v';
    'simpleTriac.idealDiode1.n.v' = 'simpleTriac.thyristor1.Gate.v';
    'L.n.v' = 'R.p.v';
    'R.n.v' = 'V.p.v';
    'trapezoidCurrent.p.v' = 'ground.p.v';
    'trapezoidCurrent.p.v' = 'simpleTriac.p.v';
    'trapezoidCurrent.p.v' = 'V.n.v';
    'simpleTriac.n.v' = 'L.p.v';
    'trapezoidCurrent.n.v' = 'simpleTriac.g.v';
    'R.p.i' + 'L.n.i' = 0.0;
    'V.p.i' + 'R.n.i' = 0.0;
    'trapezoidCurrent.p.i' + 'simpleTriac.p.i' + 'V.n.i' + 'ground.p.i' = 0.0;
    'simpleTriac.n.i' + 'L.p.i' = 0.0;
    'simpleTriac.idealDiode.n.i' + 'simpleTriac.thyristor.Gate.i' = 0.0;
    'simpleTriac.idealDiode1.p.i' + 'simpleTriac.idealDiode.p.i' - 'simpleTriac.g.i' = 0.0;
    'simpleTriac.idealDiode1.n.i' + 'simpleTriac.thyristor1.Gate.i' = 0.0;
    'trapezoidCurrent.n.i' + 'simpleTriac.g.i' = 0.0;
    'ground.p.v' = 0.0;
    2e-6 * der('L.i') = 'L.v';
    0.0 = 'L.p.i' + 'L.n.i';
    'L.i' = 'L.p.i';
    'L.v' = 'L.p.v' - 'L.n.v';
    'R.R_actual' = 10.0;
    'R.v' = 'R.R_actual' * 'R.i';
    'R.LossPower' = 'R.v' * 'R.i';
    'R.T_heatPort' = 300.15;
    0.0 = 'R.p.i' + 'R.n.i';
    'R.i' = 'R.p.i';
    'R.v' = 'R.p.v' - 'R.n.v';
    'V.signalSource.y' = if time < 0.0 then 0.0 else 30.0 * sin(62831.853071795864 * time);
    'V.v' = 'V.signalSource.y';
    0.0 = 'V.p.i' + 'V.n.i';
    'V.i' = 'V.p.i';
    'V.v' = 'V.p.v' - 'V.n.v';
    'simpleTriac.thyristor.Anode.i' + 'simpleTriac.thyristor.Gate.i' + 'simpleTriac.thyristor.Cathode.i' = 0.0;
    'simpleTriac.thyristor.vGK' = 'simpleTriac.thyristor.Gate.v' - 'simpleTriac.thyristor.Cathode.v';
    'simpleTriac.thyristor.vAK' = 'simpleTriac.thyristor.Anode.v' - 'simpleTriac.thyristor.Cathode.v';
    'simpleTriac.thyristor.iGK' = 'simpleTriac.thyristor.Gate.i';
    'simpleTriac.thyristor.vGK' = smooth(0, if 'simpleTriac.thyristor.vGK' < 0.65 then 140.0 * 'simpleTriac.thyristor.iGK' else 0.6035714285714286 + 'simpleTriac.thyristor.iGK' * 0.04999999999999993 / 0.005);
    'simpleTriac.thyristor.vContot' = 'simpleTriac.thyristor.vConmain' + smooth(0, if 'simpleTriac.thyristor.iGK' < 0.00475 then 0.0 else if 'simpleTriac.thyristor.iGK' < 0.00575 then 1e4 * ('simpleTriac.thyristor.iGK' - 0.00475) * 'simpleTriac.thyristor.vAK' else 10.0 * 'simpleTriac.thyristor.vAK');
    der('simpleTriac.thyristor.vControl') = ('simpleTriac.thyristor.vContot' - 'simpleTriac.thyristor.vControl') / (if 'simpleTriac.thyristor.vContot' - 'simpleTriac.thyristor.vControl' > 0.0 then 1.87e-6 else 9.57e-6);
    'simpleTriac.thyristor.Anode.i' = smooth(1, if 'simpleTriac.thyristor.vAK' < (-400.0) then -2.5499999999999996e-5 * exp(-('simpleTriac.thyristor.vAK' + 400.0) / 0.0296) else if 'simpleTriac.thyristor.vControl' < 1.5 then 'simpleTriac.thyristor.vAK' / 1.5686274509803923e7 else if 'simpleTriac.thyristor.vControl' < 5.0 then 'simpleTriac.thyristor.vAK' / (792.1180343813395 * 2.5499999999999997e-9 ^ ((3.0 * ((2.0 * 'simpleTriac.thyristor.vControl' - 5.0 - 1.5) / 7.0) - 4.0 * ((2.0 * 'simpleTriac.thyristor.vControl' - 5.0 - 1.5) / 7.0) ^ 3.0) / 2.0)) else 'simpleTriac.thyristor.vAK' / 0.04);
    'simpleTriac.thyristor.vConmain' = if 'simpleTriac.thyristor.Anode.i' > 0.006 or 'simpleTriac.thyristor.vAK' > 400.0 then 5.0 else 0.0;
    'simpleTriac.thyristor.LossPower' = 'simpleTriac.thyristor.Anode.i' * 'simpleTriac.thyristor.Anode.v' + 'simpleTriac.thyristor.Cathode.i' * 'simpleTriac.thyristor.Cathode.v' + 'simpleTriac.thyristor.Gate.i' * 'simpleTriac.thyristor.Gate.v';
    'simpleTriac.thyristor.T_heatPort' = 293.15;
    'simpleTriac.thyristor1.Anode.i' + 'simpleTriac.thyristor1.Gate.i' + 'simpleTriac.thyristor1.Cathode.i' = 0.0;
    'simpleTriac.thyristor1.vGK' = 'simpleTriac.thyristor1.Gate.v' - 'simpleTriac.thyristor1.Cathode.v';
    'simpleTriac.thyristor1.vAK' = 'simpleTriac.thyristor1.Anode.v' - 'simpleTriac.thyristor1.Cathode.v';
    'simpleTriac.thyristor1.iGK' = 'simpleTriac.thyristor1.Gate.i';
    'simpleTriac.thyristor1.vGK' = smooth(0, if 'simpleTriac.thyristor1.vGK' < 0.65 then 140.0 * 'simpleTriac.thyristor1.iGK' else 0.6035714285714286 + 'simpleTriac.thyristor1.iGK' * 0.04999999999999993 / 0.005);
    'simpleTriac.thyristor1.vContot' = 'simpleTriac.thyristor1.vConmain' + smooth(0, if 'simpleTriac.thyristor1.iGK' < 0.00475 then 0.0 else if 'simpleTriac.thyristor1.iGK' < 0.00575 then 1e4 * ('simpleTriac.thyristor1.iGK' - 0.00475) * 'simpleTriac.thyristor1.vAK' else 10.0 * 'simpleTriac.thyristor1.vAK');
    der('simpleTriac.thyristor1.vControl') = ('simpleTriac.thyristor1.vContot' - 'simpleTriac.thyristor1.vControl') / (if 'simpleTriac.thyristor1.vContot' - 'simpleTriac.thyristor1.vControl' > 0.0 then 1.87e-6 else 9.57e-6);
    'simpleTriac.thyristor1.Anode.i' = smooth(1, if 'simpleTriac.thyristor1.vAK' < (-400.0) then -2.5499999999999996e-5 * exp(-('simpleTriac.thyristor1.vAK' + 400.0) / 0.0296) else if 'simpleTriac.thyristor1.vControl' < 1.5 then 'simpleTriac.thyristor1.vAK' / 1.5686274509803923e7 else if 'simpleTriac.thyristor1.vControl' < 5.0 then 'simpleTriac.thyristor1.vAK' / (792.1180343813395 * 2.5499999999999997e-9 ^ ((3.0 * ((2.0 * 'simpleTriac.thyristor1.vControl' - 5.0 - 1.5) / 7.0) - 4.0 * ((2.0 * 'simpleTriac.thyristor1.vControl' - 5.0 - 1.5) / 7.0) ^ 3.0) / 2.0)) else 'simpleTriac.thyristor1.vAK' / 0.04);
    'simpleTriac.thyristor1.vConmain' = if 'simpleTriac.thyristor1.Anode.i' > 0.006 or 'simpleTriac.thyristor1.vAK' > 400.0 then 5.0 else 0.0;
    'simpleTriac.thyristor1.LossPower' = 'simpleTriac.thyristor1.Anode.i' * 'simpleTriac.thyristor1.Anode.v' + 'simpleTriac.thyristor1.Cathode.i' * 'simpleTriac.thyristor1.Cathode.v' + 'simpleTriac.thyristor1.Gate.i' * 'simpleTriac.thyristor1.Gate.v';
    'simpleTriac.thyristor1.T_heatPort' = 293.15;
    'simpleTriac.idealDiode.off' = 'simpleTriac.idealDiode.s' < 0.0;
    'simpleTriac.idealDiode.v' = 'simpleTriac.idealDiode.s' * (if 'simpleTriac.idealDiode.off' then 1.0 else 1e-5);
    'simpleTriac.idealDiode.i' = 'simpleTriac.idealDiode.s' * (if 'simpleTriac.idealDiode.off' then 1e-5 else 1.0);
    'simpleTriac.idealDiode.LossPower' = 'simpleTriac.idealDiode.v' * 'simpleTriac.idealDiode.i';
    'simpleTriac.idealDiode.T_heatPort' = 293.15;
    0.0 = 'simpleTriac.idealDiode.p.i' + 'simpleTriac.idealDiode.n.i';
    'simpleTriac.idealDiode.i' = 'simpleTriac.idealDiode.p.i';
    'simpleTriac.idealDiode.v' = 'simpleTriac.idealDiode.p.v' - 'simpleTriac.idealDiode.n.v';
    'simpleTriac.idealDiode1.off' = 'simpleTriac.idealDiode1.s' < 0.0;
    'simpleTriac.idealDiode1.v' = 'simpleTriac.idealDiode1.s' * (if 'simpleTriac.idealDiode1.off' then 1.0 else 1e-5);
    'simpleTriac.idealDiode1.i' = 'simpleTriac.idealDiode1.s' * (if 'simpleTriac.idealDiode1.off' then 1e-5 else 1.0);
    'simpleTriac.idealDiode1.LossPower' = 'simpleTriac.idealDiode1.v' * 'simpleTriac.idealDiode1.i';
    'simpleTriac.idealDiode1.T_heatPort' = 293.15;
    0.0 = 'simpleTriac.idealDiode1.p.i' + 'simpleTriac.idealDiode1.n.i';
    'simpleTriac.idealDiode1.i' = 'simpleTriac.idealDiode1.p.i';
    'simpleTriac.idealDiode1.v' = 'simpleTriac.idealDiode1.p.v' - 'simpleTriac.idealDiode1.n.v';
    'simpleTriac.LossPower' = 'simpleTriac.p.i' * 'simpleTriac.p.v' + 'simpleTriac.n.i' * 'simpleTriac.n.v' + 'simpleTriac.g.i' * 'simpleTriac.g.v';
    'simpleTriac.T_heatPort' = 293.15;

    when time >= (pre('trapezoidCurrent.signalSource.count') + 1) * 5e-5 + 2e-5 then
      'trapezoidCurrent.signalSource.count' = pre('trapezoidCurrent.signalSource.count') + 1;
      'trapezoidCurrent.signalSource.T_start' = time;
    end when;

    'trapezoidCurrent.signalSource.y' = if time < 2e-5 then 0.0 else if time < 'trapezoidCurrent.signalSource.T_start' + 1e-6 then 0.005 * (time - 'trapezoidCurrent.signalSource.T_start') / 1e-6 else if time < 'trapezoidCurrent.signalSource.T_start' + 6e-6 then 0.005 else if time < 'trapezoidCurrent.signalSource.T_start' + 7e-6 then 0.005 * ('trapezoidCurrent.signalSource.T_start' + 7e-6 - time) / 1e-6 else 0.0;
    'trapezoidCurrent.i' = 'trapezoidCurrent.signalSource.y';
    0.0 = 'trapezoidCurrent.p.i' + 'trapezoidCurrent.n.i';
    'trapezoidCurrent.i' = 'trapezoidCurrent.p.i';
    'trapezoidCurrent.v' = 'trapezoidCurrent.p.v' - 'trapezoidCurrent.n.v';
  initial algorithm
    'trapezoidCurrent.signalSource.count' := integer((time - 2e-5) / 5e-5);
    'trapezoidCurrent.signalSource.T_start' := 2e-5 + 'trapezoidCurrent.signalSource.count' * 5e-5;
    annotation(experiment(StopTime = 0.001, Interval = 5e-7, Tolerance = 1e-12));
  end 'SimpleTriacCircuit';
