//! base 0.1.0
package 'LightningSegmentedTransmissionLine'
  type 'Modelica.Electrical.Analog.Types.ImpulseApproximation' = enumeration('DoubleExp', 'Heidler');

  model 'LightningSegmentedTransmissionLine' "Lightning on a segmented transmission line"
    parameter Real 'Rload'(unit = "Ohm", quantity = "Resistance") = 200.0 "Load resistance";
    parameter Real 'r'(min = 2.2250738585072014e-308, unit = "Ohm/m") = 2.5e-5 "Resistance per meter";
    parameter Real 'g'(min = 2.2250738585072014e-308, unit = "S/m") = 1.5e-11 "Conductance per meter";
    parameter Real 'l'(min = 2.2250738585072014e-308, unit = "H/m") = 1e-6 "Inductance per meter";
    parameter Real 'c'(min = 2.2250738585072014e-308, unit = "F/m") = 1.5e-11 "Capacitance per meter";
    parameter Real 'len'(unit = "m", quantity = "Length") = 1e5 "Length of line";
    parameter Integer 'N' = 100 "Number of segments";
    Real 'line1.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.p3.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'line1.p3.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'line1.v13'(unit = "V", quantity = "ElectricPotential");
    Real 'line1.v23'(unit = "V", quantity = "ElectricPotential");
    Real 'line1.i1'(unit = "A", quantity = "ElectricCurrent");
    Real 'line1.i2'(unit = "A", quantity = "ElectricCurrent");
    parameter Real 'line1.r'(start = 1.0, min = 2.2250738585072014e-308, unit = "Ohm/m") = 2.5e-5 "Resistance per meter";
    parameter Real 'line1.l'(start = 1.0, min = 2.2250738585072014e-308, unit = "H/m") = 1e-6 "Inductance per meter";
    parameter Real 'line1.g'(start = 1.0, min = 2.2250738585072014e-308, unit = "S/m") = 1.5e-11 "Conductance per meter";
    parameter Real 'line1.c'(start = 1.0, min = 2.2250738585072014e-308, unit = "F/m") = 1.5e-11 "Capacitance per meter";
    parameter Real 'line1.length'(start = 1.0, min = 2.2250738585072014e-308, unit = "m", quantity = "Length") = 5e4 "Length of line";
    parameter Integer 'line1.N'(start = 1, min = 1) = 100 "Number of lumped segments";
    parameter Real 'line1.alpha_R'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(heatPort.T - T_ref))";
    parameter Real 'line1.alpha_G'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of conductance (G_actual = G/(1 + alpha*(heatPort.T - T_ref))";
    parameter Boolean 'line1.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'line1.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 293.15 "Fixed device temperature if useHeatPort = false";
