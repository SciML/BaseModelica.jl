//! base 0.1.0
package 'Differentiator'
  type 'Modelica.Blocks.Types.LimiterHomotopy' = enumeration('NoHomotopy', 'Linear', 'UpperLimit', 'LowerLimit');

  model 'Differentiator' "Differentiating amplifier"
    parameter Real 'Vin'(unit = "V", quantity = "ElectricPotential") = 5.0 "Amplitude of input voltage";
    parameter Real 'f'(unit = "Hz", quantity = "Frequency") = 10.0 "Frequency of input voltage";
    Real 'ground.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'ground.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'vIn.V'(start = 1.0, unit = "V", quantity = "ElectricPotential") = 10.0 "Amplitude of trapezoid";
    parameter Real 'vIn.rising'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.width'(start = 0.5, min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.falling'(start = 0.0, min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.nperiod'(start = -1) = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'vIn.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vIn.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vIn.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'vIn.signalSource.amplitude' = 10.0 "Amplitude of trapezoid";
    parameter Real 'vIn.signalSource.rising'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Rising duration of trapezoid";
    parameter Real 'vIn.signalSource.width'(min = 0.0, unit = "s", quantity = "Time") = 0.03 "Width duration of trapezoid";
    parameter Real 'vIn.signalSource.falling'(min = 0.0, unit = "s", quantity = "Time") = 0.02 "Falling duration of trapezoid";
    parameter Real 'vIn.signalSource.period'(start = 1.0, min = 2.2250738585072014e-308, unit = "s", quantity = "Time") = 0.1 "Time for one period";
    parameter Integer 'vIn.signalSource.nperiod' = -1 "Number of periods (< 0 means infinite number of periods)";
    Real 'vIn.signalSource.y' "Connector of Real output signal";
    parameter Real 'vIn.signalSource.offset' = -5.0 "Offset of output signal y";
    parameter Real 'vIn.signalSource.startTime'(unit = "s", quantity = "Time") = -0.035 "Output y = offset for time < startTime";
    parameter Real 'vIn.signalSource.T_rising'(unit = "s", quantity = "Time") = 0.02 "End time of rising phase within one period";
    parameter Real 'vIn.signalSource.T_width'(unit = "s", quantity = "Time") = 0.05 "End time of width phase within one period";
    parameter Real 'vIn.signalSource.T_falling'(unit = "s", quantity = "Time") = 0.07 "End time of falling phase within one period";
    Real 'vIn.signalSource.T_start'(unit = "s", quantity = "Time") "Start time of current period";
    Integer 'vIn.signalSource.count' "Period count";
    parameter Real 'vIn.offset'(unit = "V", quantity = "ElectricPotential") = -5.0 "Voltage offset";
    parameter Real 'vIn.startTime'(unit = "s", quantity = "Time") = -0.035 "Time offset";
    Real 'vOut.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'vOut.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'vOut.v'(unit = "V") "Voltage between pin p and n (= p.v - n.v) as output signal";
    Real 'der_.v1'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 1 (= p1.v - n1.v)";
    Real 'der_.v2'(unit = "V", quantity = "ElectricPotential") "Voltage drop of port 2 (= p2.v - n2.v)";
    Real 'der_.i1'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 1";
    Real 'der_.i2'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pos. to neg. pin of port 2";
    Real 'der_.p1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.p1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.n1.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.n1.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.p2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.p2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.n2.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.n2.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    parameter Real 'der_.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply";
    parameter Real 'der_.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply";
    parameter Real 'der_.V0' = 15000.0 "No-load amplification";
    parameter Real 'der_.opAmp.V0' = 15000.0 "No-load amplification";
    parameter Boolean 'der_.opAmp.useSupply' = false "Use supply pins (otherwise constant supply)" annotation(Evaluate = true);
    parameter Real 'der_.opAmp.Vps'(unit = "V", quantity = "ElectricPotential") = 15.0 "Positive supply voltage";
    parameter Real 'der_.opAmp.Vns'(unit = "V", quantity = "ElectricPotential") = -15.0 "Negative supply voltage";
    parameter Boolean 'der_.opAmp.strict' = true "= true, if strict limits with noEvent(..)" annotation(Evaluate = true);
    parameter 'Modelica.Blocks.Types.LimiterHomotopy' 'der_.opAmp.homotopyType' = 'Modelica.Blocks.Types.LimiterHomotopy'.'NoHomotopy' "Simplified model for homotopy-based initialization" annotation(Evaluate = true);
    Real 'der_.opAmp.vps'(unit = "V", quantity = "ElectricPotential") "Positive supply voltage";
    Real 'der_.opAmp.vns'(unit = "V", quantity = "ElectricPotential") "Negative supply voltage";
    Real 'der_.opAmp.v_in'(unit = "V", quantity = "ElectricPotential") "Input voltage difference";
    Real 'der_.opAmp.v_out'(unit = "V", quantity = "ElectricPotential") "Output voltage to ground";
    Real 'der_.opAmp.p_in'(unit = "W", quantity = "Power") "Input power";
    Real 'der_.opAmp.p_out'(unit = "W", quantity = "Power") "Output power";
    Real 'der_.opAmp.p_s'(unit = "W", quantity = "Power") "Supply power";
    Real 'der_.opAmp.i_s'(unit = "A", quantity = "ElectricCurrent") "Supply current";
    Real 'der_.opAmp.in_p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.opAmp.in_p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.opAmp.in_n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.opAmp.in_n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.opAmp.out.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.opAmp.out.i'(fixed = false, start = 0.0, unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.opAmp.simplifiedExpr'(unit = "V", quantity = "ElectricPotential") "Simplified expression for homotopy-based initialization";
    parameter Real 'der_.k'(min = 0.0) = 2.0 "Desired amplification at frequency f";
    parameter Real 'der_.f'(unit = "Hz", quantity = "Frequency") = 10.0 "Frequency";
    parameter Real 'der_.R'(unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at output of OpAmp";
    parameter Real 'der_.C'(min = 0.0, unit = "F", quantity = "Capacitance") = 3.183098861837907e-5 "Calculated capacitance to reach desired amplification k";
    Real 'der_.v'(fixed = true, start = 0.0, unit = "V", quantity = "ElectricPotential") "Capacitor voltage = state";
    Real 'der_.c.v'(start = 0.0, unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'der_.c.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.c.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.c.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.c.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.c.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Real 'der_.c.C'(start = 1.0, min = 0.0, unit = "F", quantity = "Capacitance") = 3.183098861837907e-5 "Capacitance";
    parameter Real 'der_.r.R'(start = 1.0, unit = "Ohm", quantity = "Resistance") = 1000.0 "Resistance at temperature T_ref";
    parameter Real 'der_.r.T_ref'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Reference temperature";
    parameter Real 'der_.r.alpha'(unit = "1/K", quantity = "LinearTemperatureCoefficient") = 0.0 "Temperature coefficient of resistance (R_actual = R*(1 + alpha*(T_heatPort - T_ref))";
    Real 'der_.r.v'(unit = "V", quantity = "ElectricPotential") "Voltage drop of the two pins (= p.v - n.v)";
    Real 'der_.r.p.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.r.p.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.r.n.v'(unit = "V", quantity = "ElectricPotential") "Potential at the pin";
    Real 'der_.r.n.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing into the pin";
    Real 'der_.r.i'(unit = "A", quantity = "ElectricCurrent") "Current flowing from pin p to pin n";
    parameter Boolean 'der_.r.useHeatPort' = false "= true, if heatPort is enabled" annotation(Evaluate = true);
    parameter Real 'der_.r.T'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") = 300.15 "Fixed device temperature if useHeatPort = false";
    Real 'der_.r.LossPower'(unit = "W", quantity = "Power") "Loss power leaving component via heatPort";
    Real 'der_.r.T_heatPort'(nominal = 300.0, start = 288.15, min = 0.0, displayUnit = "degC", unit = "K", quantity = "ThermodynamicTemperature") "Temperature of heatPort";
    Real 'der_.r.R_actual'(unit = "Ohm", quantity = "Resistance") "Actual resistance = R*(1 + alpha*(T_heatPort - T_ref))";
  equation
    'der_.opAmp.v_in' = 'der_.opAmp.in_p.v' - 'der_.opAmp.in_n.v';
    'der_.opAmp.v_out' = 'der_.opAmp.out.v';
    'der_.opAmp.p_in' = 'der_.opAmp.in_p.v' * 'der_.opAmp.in_p.i' + 'der_.opAmp.in_n.v' * 'der_.opAmp.in_n.i';
    'der_.opAmp.p_out' = 'der_.opAmp.out.v' * 'der_.opAmp.out.i';
    'der_.opAmp.p_s' = -('der_.opAmp.p_in' + 'der_.opAmp.p_out');
    'der_.opAmp.i_s' = 'der_.opAmp.p_s' / ('der_.opAmp.vps' - 'der_.opAmp.vns');
    'der_.v' = 'der_.c.v';
    'der_.n1.v' = 'der_.opAmp.in_p.v';
    'der_.n1.v' = 'der_.n2.v';
    'der_.opAmp.in_p.i' - 'der_.n1.i' - 'der_.n2.i' = 0.0;
    'der_.opAmp.out.v' = 'der_.r.p.v';
    'der_.opAmp.out.v' = 'der_.p2.v';
    'der_.r.p.i' + 'der_.opAmp.out.i' - 'der_.p2.i' = 0.0;
    'der_.opAmp.in_n.v' = 'der_.r.n.v';
    'der_.opAmp.in_n.v' = 'der_.c.n.v';
    'der_.c.p.v' = 'der_.p1.v';
    'vIn.p.v' = 'der_.p1.v';
    'der_.n1.v' = 'ground.p.v';
    'der_.n1.v' = 'vIn.n.v';
    'der_.p2.v' = 'vOut.p.v';
    'der_.n2.v' = 'vOut.n.v';
    'der_.p1.i' + 'vIn.p.i' = 0.0;
    'der_.n1.i' + 'vIn.n.i' + 'ground.p.i' = 0.0;
    'der_.p2.i' + 'vOut.p.i' = 0.0;
    'der_.n2.i' + 'vOut.n.i' = 0.0;
    'der_.c.p.i' - 'der_.p1.i' = 0.0;
    'der_.r.n.i' + 'der_.c.n.i' + 'der_.opAmp.in_n.i' = 0.0;
    'ground.p.v' = 0.0;

    when time >= (pre('vIn.signalSource.count') + 1) * 0.1 - 0.035 then
      'vIn.signalSource.count' = pre('vIn.signalSource.count') + 1;
      'vIn.signalSource.T_start' = time;
    end when;

    'vIn.signalSource.y' = (if time < (-0.035) then 0.0 else if time < 'vIn.signalSource.T_start' + 0.02 then 10.0 * (time - 'vIn.signalSource.T_start') / 0.02 else if time < 'vIn.signalSource.T_start' + 0.05 then 10.0 else if time < 'vIn.signalSource.T_start' + 0.07 then 10.0 * ('vIn.signalSource.T_start' + 0.07 - time) / 0.02 else 0.0) - 5.0;
    'vIn.v' = 'vIn.signalSource.y';
    0.0 = 'vIn.p.i' + 'vIn.n.i';
    'vIn.i' = 'vIn.p.i';
    'vIn.v' = 'vIn.p.v' - 'vIn.n.v';
    'vOut.p.i' = 0.0;
    'vOut.n.i' = 0.0;
    'vOut.v' = 'vOut.p.v' - 'vOut.n.v';
    'der_.opAmp.vps' = 15.0;
    'der_.opAmp.vns' = -15.0;
    'der_.opAmp.in_p.i' = 0.0;
    'der_.opAmp.in_n.i' = 0.0;
    'der_.opAmp.simplifiedExpr' = 0.0;
    'der_.opAmp.v_out' = smooth(0, noEvent(if 15000.0 * 'der_.opAmp.v_in' > 'der_.opAmp.vps' then 'der_.opAmp.vps' else if 15000.0 * 'der_.opAmp.v_in' < 'der_.opAmp.vns' then 'der_.opAmp.vns' else 15000.0 * 'der_.opAmp.v_in'));
    'der_.c.i' = 3.183098861837907e-5 * der('der_.c.v');
    0.0 = 'der_.c.p.i' + 'der_.c.n.i';
    'der_.c.i' = 'der_.c.p.i';
    'der_.c.v' = 'der_.c.p.v' - 'der_.c.n.v';
    'der_.r.R_actual' = 1000.0;
    'der_.r.v' = 'der_.r.R_actual' * 'der_.r.i';
    'der_.r.LossPower' = 'der_.r.v' * 'der_.r.i';
    'der_.r.T_heatPort' = 300.15;
    0.0 = 'der_.r.p.i' + 'der_.r.n.i';
    'der_.r.i' = 'der_.r.p.i';
    'der_.r.v' = 'der_.r.p.v' - 'der_.r.n.v';
    'der_.v1' = 'der_.p1.v' - 'der_.n1.v';
    'der_.v2' = 'der_.p2.v' - 'der_.n2.v';
    'der_.i1' = 'der_.p1.i';
    'der_.i2' = 'der_.p2.i';
  initial algorithm
    'vIn.signalSource.count' := integer((time + 0.035) / 0.1);
    'vIn.signalSource.T_start' := 'vIn.signalSource.count' * 0.1 - 0.035;
    annotation(experiment(StartTime = 0, StopTime = 1, Tolerance = 1e-006, Interval = 0.001));
  end 'Differentiator';
end 'Differentiator';
